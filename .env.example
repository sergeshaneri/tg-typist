# Copy to .env for local development. Keep real secrets out of git.

ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000

TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-random-webhook-secret
PUBLIC_WEBHOOK_BASE_URL=https://replace-with-public-url.example

DEEPSEEK_API_KEY=replace-with-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_RETRIES=2

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tg_typist

ADMIN_TELEGRAM_IDS=
MAX_MESSAGE_CHARS=4000
RATE_LIMIT_MESSAGES=20
RATE_LIMIT_WINDOW_SECONDS=60
